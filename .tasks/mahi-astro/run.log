201,168,76,0.05); }\n  .highlight-box {\n    background: linear-gradient(135deg, rgba(201,168,76,0.1), rgba(111,66,120,0.1));\n    border-left: 4px solid var(--gold); padding: 1.5rem; border-radius: 0 12px 12px 0; margin: 1.5rem 0;\n  }\n  .citation {\n    font-size: 0.85rem; color: var(--dim); border-left: 3px solid var(--gold);\n    padding-left: 1rem; margin: 0.5rem 0;\n  }\n  .citation a { color: var(--primary); }\n  .recommendation {\n    background: rgba(16,185,129,0.1); border: 1px solid rgba(16,185,129,0.3);\n    border-radius: 12px; padding: 1.5rem; margin: 1.5rem 0;\n  }\n  .recommendation h3 { color: var(--green); margin-top: 0; }\n  .faq { margin: 1rem 0; }\n  .faq details { margin-bottom: 0.75rem; }\n  .faq summary {\n    cursor: pointer; font-weight: 600; padding: 0.75rem 1rem;\n    background: var(--surface); border: 1px solid var(--border); border-radius: 8px;\n  }\n  .faq details[open] summary { border-radius: 8px 8px 0 0; }\n  .faq .answer { padding: 1rem; border: 1px solid var(--border); border-top: 0; border-radius: 0 0 8px 8px; }\n  .keyword-list { display: flex; flex-wrap: wrap; gap: 0.4rem; margin: 0.5rem 0; }\n  .keyword {\n    background: rgba(111,66,120,0.1); border: 1px solid rgba(111,66,120,0.3);\n    padding: 0.2rem 0.6rem; border-radius: 999px; font-size: 0.8rem;\n  }\n  .service-header { display: flex; align-items: center; gap: 1rem; margin-bottom: 1rem; }\n  .service-icon { font-size: 2rem; }\n  @media (max-width: 768px) {\n    .sidebar { display: none; }\n    .main { margin-left: 0; padding: 1.5rem; }\n  }\n</style>\n</head>\n<body>\n\n<div class=\"sidebar\">\n  <h1>R2 — Service Content</h1>\n  <p class=\"subtitle\">Believe Astrology — 12 Services Research</p>\n\n  <div class=\"nav-section\">\n    <h3>Overview</h3>\n    <a class=\"nav-link active\" onclick=\"showTab('executive')\">Executive Summary</a>\n    <a class=\"nav-link\" onclick=\"showTab('keywords')\">Keywords & SEO</a>\n    <a class=\"nav-link\" onclick=\"showTab('blog')\">Blog Topics</a>\n    <a class=\"nav-link\" onclick=\"showTab('citations')\">Citations</a>\n  </div>\n\n  <div class=\"nav-section\">\n    <h3>Core Astrology</h3>\n    <a class=\"nav-link\" onclick=\"showTab('s1')\">1. Kundli Reading</a>\n    <a class=\"nav-link\" onclick=\"showTab('s2')\">2. Horoscope Analysis</a>\n    <a class=\"nav-link\" onclick=\"showTab('s3')\">3. Life Guidance</a>\n    <a class=\"nav-link\" onclick=\"showTab('s4')\">4. Vastu Consultation</a>\n    <a class=\"nav-link\" onclick=\"showTab('s5')\">5. Gemstone Recs</a>\n    <a class=\"nav-link\" onclick=\"showTab('s6')\">6. Karma Counselling</a>\n  </div>\n\n  <div class=\"nav-section\">\n    <h3>Spiritual Services</h3>\n    <a class=\"nav-link\" onclick=\"showTab('s7')\">7. Pancha Tatva</a>\n    <a class=\"nav-link\" onclick=\"showTab('s8')\">8. Seven Chakras</a>\n    <a class=\"nav-link\" onclick=\"showTab('s9')\">9. Vedic Poojas</a>\n    <a class=\"nav-link\" onclick=\"showTab('s10')\">10. Karma-Kand Yagnas</a>\n    <a class=\"nav-link\" onclick=\"showTab('s11')\">11. Maha Mrityunjaya</a>\n    <a class=\"nav-link\" onclick=\"showTab('s12')\">12. Mantras Chanting</a>\n  </div>\n</div>\n\n<div class=\"main\">\n\n<!-- EXECUTIVE SUMMARY -->\n<div id=\"executive\" class=\"tab-content active\">\n  <h2>Executive Summary</h2>\n\n  <div class=\"highlight-box\">\n    <p><strong>Research Scope:</strong> In-depth content research for all 12 services offered by Pandit Shree Mahadev Joshi at Believe Astrology. Each service includes a 300-500 word description, benefits, consultation process, FAQs, multilingual keywords, and related blog topic ideas.</p>\n  </div>\n\n  <h3>Service Categories</h3>\n  <p>The 12 services fall into two natural groups:</p>\n\n  <div class=\"card\">\n    <h4>Core Astrology Services (1-6)</h4>\n    <p>Analytical and consultative services based on birth chart interpretation, planetary analysis, and personalized life guidance. These are the primary revenue drivers and entry points for new clients.</p>\n    <ul>\n      <li><strong>Vedic Astrology &amp; Kundli Reading</strong> — Foundation service, gateway to all others</li>\n      <li><strong>Horoscope Analysis &amp; Predictions</strong> — Ongoing engagement through yearly/monthly forecasts</li>\n      <li><strong>Marriage, Career, Finance &amp; Health Guidance</strong> — Practical life decisions</li>\n      <li><strong>Vastu Consultation</strong> — Space/architecture harmony (high ticket)</li>\n      <li><strong>Gemstone Recommendations</strong> — Remedial with product tie-in</li>\n      <li><strong>Karma &amp; Life-Purpose Counselling</strong> — Deep spiritual counselling</li>\n    </ul>\n  </div>\n\n  <div class=\"card\">\n    <h4>Spiritual Healing Services (7-12)</h4>\n    <p>Ritual-based and energy-healing services rooted in Vedic tradition. These require deeper trust and typically come after an initial consultation.</p>\n    <ul>\n      <li><strong>Pancha Tatva Balancing</strong> — Five-element harmony</li>\n      <li><strong>Seven Chakras Balancing</strong> — Energy center alignment</li>\n      <li><strong>Vedic Spiritual Poojas</strong> — Ceremonial worship rituals</li>\n      <li><strong>Vedic Karma-Kand Yagnas</strong> — Sacred fire ceremonies</li>\n      <li><strong>Maha Mrityunjaya Mantra Anushthan</strong> — Healing ritual for longevity</li>\n      <li><strong>Mantras Chanting</strong> — Sound-based spiritual practice</li>\n    </ul>\n  </div>\n\n  <div class=\"recommendation\">\n    <h3>Content Strategy Recommendation</h3>\n    <ul>\n      <li><strong>Lead with Kundli Reading</strong> — it's the gateway service. Most users search for \"free kundli\" or \"janam kundali\" first.</li>\n      <li><strong>Cross-link services</strong> — Every service page should link to related services (e.g., Kundli → Gemstone Recs → Mantras).</li>\n      <li><strong>Use FAQ schema</strong> — Each service has FAQs; implement FAQ structured data for Google rich snippets.</li>\n      <li><strong>Blog content supports SEO</strong> — Each service has 3-5 blog topics that drive organic traffic to the service page.</li>\n      <li><strong>Multilingual keywords are essential</strong> — Hindi and Gujarati users search in their native language. Target both Devanagari and Romanized queries.</li>\n    </ul>\n  </div>\n</div>\n\n<!-- KEYWORDS & SEO -->\n<div id=\"keywords\" class=\"tab-content\">\n  <h2>Keywords &amp; SEO Strategy</h2>\n\n  <h3>Keyword Matrix by Service</h3>\n  <table>\n    <thead>\n      <tr><th>Service</th><th>English Keywords</th><th>Hindi Keywords</th><th>Gujarati Keywords</th></tr>\n    </thead>\n    <tbody>\n      <tr>\n        <td>Kundli Reading</td>\n        <td>vedic astrology, kundli reading, birth chart analysis, janam kundali, free kundli online</td>\n        <td>कुंडली, जन्म कुंडली, वैदिक ज्योतिष, राशिफल, ग्रह दशा</td>\n        <td>કુંડળી, જન્માક્ષર, વૈદિક જ્યોતિષ, રાશિફળ, ગ્રહ દશા</td>\n      </tr>\n      <tr>\n        <td>Horoscope Analysis</td>\n        <td>horoscope prediction, yearly horoscope 2026, zodiac forecast, rashifal, moon sign horoscope</td>\n        <td>राशिफल, वार्षिक राशिफल 2026, दैनिक राशिफल, मासिक भविष्यफल</td>\n        <td>રાશિફળ, વાર્ષિક રાશિફળ 2026, દૈનિક રાશિફળ, ભવિષ્યફળ</td>\n      </tr>\n      <tr>\n        <td>Life Guidance</td>\n        <td>marriage astrology, career astrology, financial astrology, health horoscope, kundli matching</td>\n        <td>विवाह ज्योतिष, करियर ज्योतिष, कुंडली मिलान, स्वास्थ्य ज्योतिष, धन योग</td>\n        <td>લગ્ન જ્યોતિષ, કારકિર્દી જ્યોતિષ, કુંડળી મિલાન, સ્વાસ્થ્ય જ્યોતિષ</td>\n      </tr>\n      <tr>\n        <td>Vastu Consultation</td>\n        <td>vastu shastra, vastu consultant, home vastu, office vastu, vastu tips, vastu remedies</td>\n        <td>वास्तु शास्त्र, वास्तु सलाहकार, घर का वास्तु, वास्तु दोष, वास्तु उपाय</td>\n        <td>વાસ્તુ શાસ્ત્ર, વાસ્તુ સલાહકાર, ઘરનું વાસ્તુ, વાસ્તુ દોષ, વાસ્તુ ઉપાય</td>\n      </tr>\n      <tr>\n        <td>Gemstone Recs</td>\n        <td>gemstone astrology, jyotish ratna, navratna, lucky stone by birth, gemstone recommendation</td>\n        <td>रत्न ज्योतिष, नवरत्न, भाग्यशाली रत्न, राशि रत्न, नीलम, पुखराज</td>\n        <td>રત્ન જ્યોતિષ, નવરત્ન, ભાગ્યશાળી રત્ન, રાશિ રત્ન</td>\n      </tr>\n      <tr>\n        <td>Karma Counselling</td>\n        <td>karma astrology, life purpose astrology, past life karma, spiritual counselling, dharma path</td>\n        <td>कर्म ज्योतिष, जीवन उद्देश्य, पूर्व जन्म कर्म, आध्यात्मिक मार्गदर्शन</td>\n        <td>કર્મ જ્યોતિષ, જીવન ઉદ્દેશ્ય, પૂર્વ જન્મ કર્મ, આધ્યાત્મિક માર્ગદર્શન</td>\n      </tr>\n      <tr>\n        <td>Pancha Tatva</td>\n        <td>pancha tatva, five elements balancing, prithvi jal agni vayu akash, elemental healing</td>\n        <td>पंच तत्व, पांच तत्व संतुलन, पृथ्वी जल अग्नि वायु आकाश</td>\n        <td>પંચ તત્વ, પાંચ તત્વ સંતુલન, પૃથ્વી જળ અગ્નિ વાયુ આકાશ</td>\n      </tr>\n      <tr>\n        <td>Seven Chakras</td>\n        <td>chakra balancing, seven chakras healing, kundalini, energy healing, chakra meditation</td>\n        <td>सात चक्र, चक्र संतुलन, कुंडलिनी, ऊर्जा चिकित्सा, चक्र ध्यान</td>\n        <td>સાત ચક્ર, ચક્ર સંતુલન, કુંડલિની, ઊર્જા ચિકિત્સા</td>\n      </tr>\n      <tr>\n        <td>Vedic Poojas</td>\n        <td>vedic puja, hindu puja service, online puja booking, ganesh puja, lakshmi puja, navgraha puja</td>\n        <td>वैदिक पूजा, हिंदू पूजा, ऑनलाइन पूजा, गणेश पूजा, लक्ष्मी पूजा, नवग्रह पूजा</td>\n        <td>વૈદિક પૂજા, હિંદુ પૂજા, ગણેશ પૂજા, લક્ષ્મી પૂજા, નવગ્રહ પૂજા</td>\n      </tr>\n      <tr>\n        <td>Karma-Kand Yagnas</td>\n        <td>vedic yagna, havan, homa, fire ceremony, karma kand, agnihotra, navagraha homa</td>\n        <td>वैदिक यज्ञ, हवन, होम, अग्निहोत्र, कर्मकांड, नवग्रह होम</td>\n        <td>વૈદિક યજ્ઞ, હવન, હોમ, અગ્નિહોત્ર, કર્મકાંડ, નવગ્રહ હોમ</td>\n      </tr>\n      <tr>\n        <td>Maha Mrityunjaya</td>\n        <td>maha mrityunjaya mantra, mrityunjaya anushthan, shiva healing mantra, longevity ritual</td>\n        <td>महा मृत्युंजय मंत्र, मृत्युंजय अनुष्ठान, शिव मंत्र, आयुष्य मंत्र</td>\n        <td>મહા મૃત્યુંજય મંત્ર, મૃત્યુંજય અનુષ્ઠાન, શિવ મંત્ર</td>\n      </tr>\n      <tr>\n        <td>Mantras Chanting</td>\n        <td>vedic mantras, mantra chanting, beej mantra, planetary mantras, gayatri mantra, mantra healing</td>\n        <td>वैदिक मंत्र, मंत्र जाप, बीज मंत्र, ग्रह मंत्र, गायत्री मंत्र</td>\n        <td>વૈદિક મંત્ર, મંત્ર જાપ, બીજ મંત્ર, ગ્રહ મંત્ર, ગાયત્રી મંત્ર</td>\n      </tr>\n    </tbody>\n  </table>\n\n  <div class=\"recommendation\">\n    <h3>SEO Strategy Notes</h3>\n    <ul>\n      <li>Target both Devanagari script and Romanized Hindi keywords (e.g., \"rashifal\" and \"राशिफल\")</li>\n      <li>Long-tail keywords in local language dominate: \"ahmedabad best astrologer\" / \"અમદાવાદ શ્રેષ્ઠ જ્યોતિષ\"</li>\n      <li>FAQ schema markup on every service page for Google rich snippets</li>\n      <li>Each service page needs 1500+ words for competitive SEO in the astrology niche</li>\n      <li>Add location-specific keywords: Ahmedabad, Gujarat, Mumbai, India</li>\n    </ul>\n  </div>\n</div>\n\n<!-- BLOG TOPICS -->\n<div id=\"blog\" class=\"tab-content\">\n  <h2>Blog Topics by Service</h2>\n\n  <table>\n    <thead>\n      <tr><th>Service</th><th>Blog Topic Ideas</th></tr>\n    </thead>\n    <tbody>\n      <tr>\n        <td>Kundli Reading</td>\n        <td>\n          <ul>\n            <li>What is a Kundli? A Complete Beginner's Guide to Your Birth Chart</li>\n            <li>How Accurate is Vedic Astrology? Understanding the Science Behind Kundli</li>\n            <li>5 Things Your Kundli Reveals About Your Personality</li>\n            <li>Kundli vs Western Birth Chart: Key Differences Explained</li>\n          </ul>\n        </td>\n      </tr>\n      <tr>\n        <td>Horoscope Analysis</td>\n        <td>\n          <ul>\n            <li>Your Complete 2026 Rashifal: What the Stars Hold for Each Zodiac Sign</li>\n            <li>Understanding Planetary Transits: How They Affect Your Daily Life</li>\n            <li>Saturn in Pisces 2026: Career and Financial Impact on All Signs</li>\n            <li>Moon Sign vs Sun Sign: Which Matters More in Vedic Astrology?</li>\n          </ul>\n        </td>\n      </tr>\n      <tr>\n        <td>Life Guidance</td>\n        <td>\n          <ul>\n            <li>How Astrology Can Guide Your Career Choice: A Vedic Perspective</li>\n            <li>Kundli Matching for Marriage: Why It Matters and How It Works</li>\n            <li>Best Astrological Timing for Property and Investment Decisions</li>\n            <li>Health Indicators in Your Birth Chart: What to Watch For</li>\n          </ul>\n        </td>\n      </tr>\n      <tr>\n        <td>Vastu Consultation</td>\n        <td>\n          <ul>\n            <li>Vastu Tips for Your Home: Room-by-Room Guide</li>\n            <li>Vastu for Office: Boost Productivity with Directional Alignment</li>\n            <li>Common Vastu Doshas and Their Simple Remedies</li>\n            <li>Vastu vs Feng Shui: Similarities and Differences</li>\n          </ul>\n        </td>\n      </tr>\n      <tr>\n        <td>Gemstone Recs</td>\n        <td>\n          <ul>\n            <li>The Navratna Guide: 9 Gemstones and Their Planetary Powers</li>\n            <li>How to Choose the Right Gemstone According to Your Kundli</li>\n            <li>Can Wearing the Wrong Gemstone Be Harmful? Myths vs Reality</li>\n            <li>Blue Sapphire (Neelam): The Most Powerful and Dangerous Gemstone?</li>\n          </ul>\n        </td>\n      </tr>\n      <tr>\n        <td>Karma Counselling</td>\n        <td>\n          <ul>\n            <li>Understanding Karma in Vedic Astrology: Sanchita, Prarabdha, and Kriyamana</li>\n            <li>Rahu and Ketu: Your Past Life Karma Decoded</li>\n            <li>Can You Change Your Destiny? Free Will vs Fate in Jyotish</li>\n          </ul>\n        </td>\n      </tr>\n      <tr>\n        <td>Pancha Tatva</td>\n        <td>\n     