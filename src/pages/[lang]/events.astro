---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SiteHeader from '../../components/layout/SiteHeader.astro';
import MenuOverlay from '../../components/layout/MenuOverlay.astro';
import SiteFooter from '../../components/layout/SiteFooter.astro';
import WhatsAppButton from '../../components/layout/WhatsAppButton.astro';
import BottomBar from '../../components/layout/BottomBar.astro';
import SectionHeading from '../../components/ui/SectionHeading.astro';
import Button from '../../components/ui/Button.astro';
import EventCard from '../../components/sections/EventCard.astro';
import SubscribeSection from '../../components/sections/SubscribeSection.astro';
import Breadcrumbs from '../../components/ui/Breadcrumbs.astro';
import { supportedLanguages, isValidLanguage, getTranslations } from '../../utils/i18n';
import type { SupportedLanguage } from '../../utils/i18n';
import { siteConfig } from '../../data/site-config';
import events from '../../data/events.json';

export function getStaticPaths() {
  return supportedLanguages.map((lang) => ({
    params: { lang },
  }));
}

const { lang } = Astro.params;
if (!isValidLanguage(lang as string)) {
  return Astro.redirect('/en/events');
}

const currentLang = lang as SupportedLanguage;
const t = getTranslations(currentLang);
const ep = t.eventsPage;
const whatsappUrl = `${siteConfig.contact.whatsapp}?text=${encodeURIComponent(t.whatsapp.prefill)}`;
const whatsappSubscribeUrl = `${siteConfig.contact.whatsapp}?text=${encodeURIComponent(ep.whatsappSubscribePrefill)}`;

function getTitle(item: any): string {
  if (currentLang === 'hi' && item.titleHi) return item.titleHi;
  if (currentLang === 'gu' && item.titleGu) return item.titleGu;
  return item.title;
}

function getDescription(item: any): string {
  if (currentLang === 'hi' && item.descriptionHi) return item.descriptionHi;
  if (currentLang === 'gu' && item.descriptionGu) return item.descriptionGu;
  return item.description;
}

function getCategoryLabel(category: string): string {
  return (ep.categoryLabels as Record<string, string>)[category] || category;
}

const upcomingEvents = events.filter((e: any) => e.type === 'event' && e.status === 'upcoming');
const currentUpdates = events.filter((e: any) => e.type === 'update');
const pastEvents = events.filter((e: any) => e.type === 'event' && e.status === 'past');
---

<BaseLayout lang={currentLang} title={`${ep.title} | ${t.meta.title}`} description={ep.subtitle}>
  <SiteHeader slot="header" lang={currentLang} />
  <MenuOverlay slot="header" lang={currentLang} />

  <main id="main-content">
    <!-- Hero Banner -->
    <section class="hero-dark py-16 md:py-24">
      <div class="container-wide text-center">
        <Breadcrumbs lang={currentLang} items={[{ label: t.header.home, href: `/${currentLang}/` }, { label: ep.title, href: `/${currentLang}/events` }]} variant="dark" />
        <h1 class="font-heading text-4xl md:text-5xl font-bold text-gold mb-4">
          {ep.title}
        </h1>
        <p class="text-lg text-cream/80 max-w-2xl mx-auto">
          {ep.heroTagline}
        </p>
      </div>
    </section>

    <!-- Upcoming Events -->
    <section class="py-[--spacing-section-sm] md:py-[--spacing-section]" aria-labelledby="upcoming-heading">
      <div class="container-wide">
        <SectionHeading title={ep.upcomingTitle} subtitle={ep.upcomingSubtitle} align="center" />

        {upcomingEvents.length > 0 ? (
          <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
            {upcomingEvents.map((event: any) => (
              <EventCard
                icon={event.icon}
                title={getTitle(event)}
                description={getDescription(event)}
                date={event.date}
                endDate={event.endDate}
                location={event.location}
                category={event.category}
                status={event.status}
                categoryLabel={getCategoryLabel(event.category)}
                dateLabel={ep.date}
                locationLabel={ep.location}
                learnMoreLabel={ep.registerVia}
                whatsappUrl={`${siteConfig.contact.whatsapp}?text=${encodeURIComponent(`${t.whatsapp.prefill} I am interested in: ${event.title}`)}`}
              />
            ))}
          </div>
        ) : (
          <p class="text-center text-purple/60 py-8">{ep.noUpcoming}</p>
        )}
      </div>
    </section>

    <!-- Latest Updates / News Feed -->
    <section class="bg-cream-dark/30 py-[--spacing-section-sm] md:py-[--spacing-section]" aria-labelledby="updates-heading">
      <div class="container-wide">
        <SectionHeading title={ep.updatesTitle} subtitle={ep.updatesSubtitle} align="center" />

        {currentUpdates.length > 0 ? (
          <div class="grid md:grid-cols-2 gap-6 max-w-4xl mx-auto">
            {currentUpdates.map((update: any) => (
              <article class="bg-white rounded-[var(--radius-card)] shadow-[var(--shadow-card)] p-6 border-l-4 border-l-saffron">
                <div class="flex items-center gap-2 mb-3">
                  <span class="text-2xl" aria-hidden="true" set:html={update.icon} />
                  <span class="text-xs font-semibold px-3 py-1 rounded-full bg-saffron/15 text-saffron">
                    {getCategoryLabel(update.category)}
                  </span>
                </div>
                <h3 class="font-heading text-lg font-bold text-indigo mb-2">{getTitle(update)}</h3>
                <p class="text-sm text-indigo/70 leading-relaxed mb-3">{getDescription(update)}</p>
                <time class="text-xs text-purple/50">
                  {new Date(update.date + 'T00:00:00').toLocaleDateString(
                    currentLang === 'hi' ? 'hi-IN' : currentLang === 'gu' ? 'gu-IN' : 'en-IN',
                    { day: 'numeric', month: 'long', year: 'numeric' }
                  )}
                </time>
              </article>
            ))}
          </div>
        ) : (
          <p class="text-center text-purple/60 py-8">{ep.noUpdates}</p>
        )}
      </div>
    </section>

    <!-- Subscribe Section -->
    <SubscribeSection
      title={ep.subscribeTitle}
      subtitle={ep.subscribeSubtitle}
      emailLabel={ep.emailLabel}
      emailPlaceholder={ep.emailPlaceholder}
      submitLabel={ep.submitLabel}
      submittingLabel={ep.submittingLabel}
      successMessage={ep.successMessage}
      errorMessage={ep.errorMessage}
      whatsappTitle={ep.whatsappTitle}
      whatsappDescription={ep.whatsappDescription}
      whatsappCta={ep.whatsappCta}
      whatsappUrl={whatsappSubscribeUrl}
    />

    <!-- Past Events Gallery Placeholder -->
    {pastEvents.length > 0 && (
      <section class="py-[--spacing-section-sm] md:py-[--spacing-section]" aria-labelledby="past-heading">
        <div class="container-wide">
          <SectionHeading title={ep.pastTitle} subtitle={ep.pastSubtitle} align="center" />
          <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
            {pastEvents.map((event: any) => (
              <EventCard
                icon={event.icon}
                title={getTitle(event)}
                description={getDescription(event)}
                date={event.date}
                endDate={event.endDate}
                location={event.location}
                category={event.category}
                status={event.status}
                categoryLabel={getCategoryLabel(event.category)}
                dateLabel={ep.date}
                locationLabel={ep.location}
                learnMoreLabel={ep.readMore}
                whatsappUrl={whatsappUrl}
              />
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- CTA Section -->
    <section class="hero-dark py-16 md:py-24">
      <div class="container-wide text-center">
        <h2 class="font-heading text-3xl md:text-4xl font-bold text-gold mb-4">
          {ep.ctaTitle}
        </h2>
        <p class="text-lg text-cream/80 max-w-2xl mx-auto mb-8">
          {ep.ctaSubtitle}
        </p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
          <Button variant="primary" size="lg" href={whatsappUrl} target="_blank" rel="noopener noreferrer">
            <svg class="w-5 h-5 mr-2" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z" />
            </svg>
            {t.cta.button}
          </Button>
          <Button variant="outline" size="lg" href={`tel:${siteConfig.contact.phone}`} class="border-cream text-cream hover:bg-cream/10">
            {t.cta.phone}
          </Button>
        </div>
      </div>
    </section>
  </main>

  <SiteFooter slot="footer" lang={currentLang} />
  <WhatsAppButton lang={currentLang} />
  <BottomBar lang={currentLang} />
</BaseLayout>
