---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import SiteHeader from '../../../components/layout/SiteHeader.astro';
import MenuOverlay from '../../../components/layout/MenuOverlay.astro';
import SiteFooter from '../../../components/layout/SiteFooter.astro';
import WhatsAppButton from '../../../components/layout/WhatsAppButton.astro';
import BottomBar from '../../../components/layout/BottomBar.astro';
import SectionHeading from '../../../components/ui/SectionHeading.astro';
import Breadcrumbs from '../../../components/ui/Breadcrumbs.astro';
import Button from '../../../components/ui/Button.astro';
import { supportedLanguages, isValidLanguage, getTranslations } from '../../../utils/i18n';
import { getServiceBySlug, getAllServiceSlugs, getServicesForLanguage } from '../../../utils/services';
import { siteConfig } from '../../../data/site-config';
import { serviceSchema, faqSchema } from '../../../utils/schema';
import { getBlogPostBySlug } from '../../../utils/blog';
import seoKeywords from '../../../data/seo-keywords.json';
import type { SupportedLanguage } from '../../../utils/i18n';

export async function getStaticPaths() {
  const slugs = await getAllServiceSlugs();
  const paths = [];
  for (const lang of supportedLanguages) {
    for (const slug of slugs) {
      paths.push({ params: { lang, slug } });
    }
  }
  return paths;
}

const { lang, slug } = Astro.params;
if (!isValidLanguage(lang as string)) {
  return Astro.redirect('/en/');
}

const currentLang = lang as SupportedLanguage;
const t = getTranslations(currentLang);
const service = await getServiceBySlug(currentLang, slug as string);

if (!service) {
  return Astro.redirect(`/${currentLang}/services/`);
}

// Get related services
const allServices = await getServicesForLanguage(currentLang);
const relatedServices = allServices.filter((s) =>
  service.relatedServices.includes(s.slug)
);

// Get related blog posts for this service
const blogSlugs = (seoKeywords.serviceToBlogMap as Record<string, string[]>)[service.slug] || [];
const relatedBlogPosts = [];
for (const blogSlug of blogSlugs) {
  const post = await getBlogPostBySlug(currentLang, blogSlug);
  if (post) relatedBlogPosts.push(post);
}

const serviceIconMap: Record<string, string> = {
  'vedic-astrology-kundli-reading': 'kundli-reading',
  'horoscope-analysis-predictions': 'horoscope-analysis',
  'marriage-career-finance-health-guidance': 'life-guidance',
  'vastu-consultation': 'vastu',
  'gemstone-recommendations': 'gemstone',
  'karma-life-purpose-counselling': 'karma-counselling',
  'pancha-tatva-balancing': 'pancha-tatva',
  'seven-chakras-balancing': 'chakra-balancing',
  'vedic-spiritual-poojas': 'poojas',
  'vedic-karma-kand-yagnas': 'yagnas',
  'maha-mrityunjaya-mantra-anushthan': 'maha-mrityunjay',
  'mantras-chanting': 'mantras-chanting',
};

const whatsappMsg = encodeURIComponent(
  `Namaste! I would like to book a ${service.title} consultation with Pandit Shree Mahadev Joshi.`
);

const serviceJsonLd = [
  serviceSchema(service, currentLang),
  faqSchema(service.faqs),
];

const breadcrumbItems = [
  { label: t.header.home, href: `/${currentLang}/` },
  { label: t.header.services, href: `/${currentLang}/services` },
  { label: service.title, href: `/${currentLang}/services/${service.slug}` },
];
---

<BaseLayout
  lang={currentLang}
  title={service.seo.title}
  description={service.seo.description}
  ogImage={`/images/services/${service.slug}.svg`}
  jsonLd={serviceJsonLd}
>
  <SiteHeader slot="header" lang={currentLang} />
  <MenuOverlay slot="header" lang={currentLang} />

  <!-- Hero Banner -->
  <section class="hero-dark py-16 md:py-24">
    <div class="container-wide text-center">
      <Breadcrumbs lang={currentLang} items={breadcrumbItems} variant="dark" />
      <img src={`/images/icons/services/${serviceIconMap[service.slug] || 'kundli-reading'}.svg`} alt="" width="64" height="64" class="w-16 h-16 mx-auto mb-4" />
      <h1 class="font-heading text-4xl md:text-5xl font-bold text-gold mb-3">
        {service.title}
      </h1>
      <p class="text-lg text-cream/80 max-w-2xl mx-auto">
        {service.subtitle}
      </p>
      <div class="mt-8">
        <Button href={`${siteConfig.contact.whatsapp}?text=${whatsappMsg}`} variant="primary" size="lg">
          {t.cta.button}
        </Button>
      </div>
    </div>
  </section>

  <!-- Introduction -->
  <section class="py-[--spacing-section-sm] md:py-[--spacing-section]">
    <div class="container-narrow">
      <div class="prose prose-lg max-w-none">
        <p class="text-lg text-purple/90 leading-relaxed font-medium">
          {service.introduction}
        </p>
        {service.overview.split('\n\n').map((paragraph) => (
          <p class="text-purple/80 leading-relaxed mt-4">
            {paragraph}
          </p>
        ))}
      </div>
    </div>
  </section>

  <!-- Benefits -->
  <section class="py-[--spacing-section-sm] md:py-[--spacing-section] bg-cream/50">
    <div class="container-wide">
      <SectionHeading
        title="Benefits"
        subtitle={`Why choose ${service.title}`}
        align="center"
      />
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-4xl mx-auto">
        {service.benefits.map((benefit) => (
          <div class="flex items-start gap-3 p-4 bg-white rounded-lg shadow-sm">
            <span class="text-gold text-xl mt-0.5 shrink-0">&#x2714;</span>
            <p class="text-purple/80 leading-relaxed">{benefit}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Process -->
  <section class="py-[--spacing-section-sm] md:py-[--spacing-section]">
    <div class="container-wide">
      <SectionHeading
        title="How It Works"
        subtitle="Your consultation journey step by step"
        align="center"
      />
      <div class="max-w-3xl mx-auto space-y-8">
        {service.process.map((step) => (
          <div class="flex gap-6 items-start">
            <div class="shrink-0 w-12 h-12 rounded-full bg-gold text-indigo font-heading font-bold text-xl flex items-center justify-center">
              {step.step}
            </div>
            <div>
              <h3 class="font-heading text-xl font-semibold text-indigo mb-2">
                {step.title}
              </h3>
              <p class="text-purple/80 leading-relaxed">
                {step.description}
              </p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ Accordion -->
  <section class="py-[--spacing-section-sm] md:py-[--spacing-section] bg-cream/50">
    <div class="container-wide">
      <SectionHeading
        title="Frequently Asked Questions"
        align="center"
      />
      <div class="max-w-3xl mx-auto space-y-4">
        {service.faqs.map((faq, index) => (
          <details class="group bg-white rounded-lg shadow-sm border border-cream-dark overflow-hidden">
            <summary class="flex items-center justify-between cursor-pointer p-5 font-semibold text-indigo hover:text-gold transition-colors">
              <span>{faq.question}</span>
              <span class="text-gold text-xl transition-transform group-open:rotate-45">+</span>
            </summary>
            <div class="px-5 pb-5 text-purple/80 leading-relaxed border-t border-cream-dark pt-4">
              {faq.answer}
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- Related Services -->
  {relatedServices.length > 0 && (
    <section class="py-[--spacing-section-sm] md:py-[--spacing-section]">
      <div class="container-wide">
        <SectionHeading
          title="Related Services"
          subtitle="You may also be interested in"
          align="center"
        />
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 max-w-4xl mx-auto">
          {relatedServices.map((related) => (
            <a href={`/${currentLang}/services/${related.slug}`} class="block group">
              <div class="bg-white p-6 rounded-lg shadow-sm border border-cream-dark hover:shadow-md hover:-translate-y-1 transition-all">
                <img src={`/images/icons/services/${serviceIconMap[related.slug] || 'kundli-reading'}.svg`} alt="" width="40" height="40" class="w-10 h-10 mb-3" loading="lazy" />
                <h3 class="font-heading font-semibold text-indigo group-hover:text-gold transition-colors mb-2">
                  {related.title}
                </h3>
                <p class="text-sm text-purple/70">{related.shortDescription}</p>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Related Blog Articles -->
  {relatedBlogPosts.length > 0 && (
    <section class="py-[--spacing-section-sm] md:py-[--spacing-section] bg-cream/50">
      <div class="container-wide">
        <SectionHeading
          title="Related Articles"
          subtitle="Learn more about this topic"
          align="center"
        />
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 max-w-4xl mx-auto">
          {relatedBlogPosts.map((post) => (
            <a href={`/${currentLang}/blog/${post.slug}`} class="block group">
              <div class="bg-white p-6 rounded-lg shadow-sm border border-cream-dark hover:shadow-md hover:-translate-y-1 transition-all">
                <span class="text-xs font-semibold text-gold bg-gold/10 px-2 py-1 rounded-full">
                  {post.category}
                </span>
                <h3 class="font-heading font-semibold text-indigo group-hover:text-gold transition-colors mt-3 mb-2 leading-snug">
                  {post.title}
                </h3>
                <p class="text-sm text-purple/70 line-clamp-2">{post.excerpt}</p>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- CTA -->
  <section class="hero-dark py-16 md:py-20">
    <div class="container-wide text-center">
      <h2 class="font-heading text-3xl md:text-4xl font-bold text-gold mb-4">
        Book {service.title}
      </h2>
      <p class="text-cream/80 text-lg max-w-xl mx-auto mb-8">
        {t.cta.subtitle}
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <Button href={`${siteConfig.contact.whatsapp}?text=${whatsappMsg}`} variant="primary" size="lg">
          {t.cta.button}
        </Button>
        <Button href={`tel:${siteConfig.contact.phone}`} variant="outline" size="lg">
          {t.cta.phone}
        </Button>
      </div>
    </div>
  </section>

  <SiteFooter slot="footer" lang={currentLang} />
  <WhatsAppButton slot="footer" lang={currentLang} />
  <BottomBar slot="footer" lang={currentLang} />
</BaseLayout>
