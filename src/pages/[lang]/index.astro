---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SiteHeader from '../../components/layout/SiteHeader.astro';
import MenuOverlay from '../../components/layout/MenuOverlay.astro';
import SiteFooter from '../../components/layout/SiteFooter.astro';
import WhatsAppButton from '../../components/layout/WhatsAppButton.astro';
import BottomBar from '../../components/layout/BottomBar.astro';
import HeroSection from '../../components/sections/HeroSection.astro';
import StatsBar from '../../components/sections/StatsBar.astro';
import ServicesGrid from '../../components/sections/ServicesGrid.astro';
import TestimonialsSection from '../../components/sections/TestimonialsSection.astro';
import CTASection from '../../components/sections/CTASection.astro';
import { supportedLanguages, isValidLanguage } from '../../utils/i18n';
import type { SupportedLanguage } from '../../utils/i18n';

export function getStaticPaths() {
  return supportedLanguages.map((lang) => ({
    params: { lang },
  }));
}

const { lang } = Astro.params;
if (!isValidLanguage(lang as string)) {
  return Astro.redirect('/en/');
}

const currentLang = lang as SupportedLanguage;
---

<BaseLayout lang={currentLang}>
  <SiteHeader slot="header" lang={currentLang} />
  <MenuOverlay slot="header" lang={currentLang} />

  <HeroSection lang={currentLang} />
  <StatsBar lang={currentLang} />
  <ServicesGrid lang={currentLang} />
  <TestimonialsSection lang={currentLang} />
  <CTASection lang={currentLang} />

  <SiteFooter slot="footer" lang={currentLang} />
  <WhatsAppButton slot="footer" lang={currentLang} />
  <BottomBar slot="footer" lang={currentLang} />
</BaseLayout>
