---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SiteHeader from '../../components/layout/SiteHeader.astro';
import MenuOverlay from '../../components/layout/MenuOverlay.astro';
import SiteFooter from '../../components/layout/SiteFooter.astro';
import WhatsAppButton from '../../components/layout/WhatsAppButton.astro';
import BottomBar from '../../components/layout/BottomBar.astro';
import SectionHeading from '../../components/ui/SectionHeading.astro';
import Button from '../../components/ui/Button.astro';
import { supportedLanguages, isValidLanguage, getTranslations } from '../../utils/i18n';
import type { SupportedLanguage } from '../../utils/i18n';
import { siteConfig } from '../../data/site-config';
import { personSchema } from '../../utils/schema';

export function getStaticPaths() {
  return supportedLanguages.map((lang) => ({
    params: { lang },
  }));
}

const { lang } = Astro.params;
if (!isValidLanguage(lang as string)) {
  return Astro.redirect('/en/about');
}

const currentLang = lang as SupportedLanguage;
const t = getTranslations(currentLang);
const whatsappUrl = `${siteConfig.contact.whatsapp}?text=${encodeURIComponent(t.whatsapp.prefill)}`;
const aboutJsonLd = { '@context': 'https://schema.org', ...personSchema() };
---

<BaseLayout lang={currentLang} title={`${t.about.title} | ${t.meta.title}`} description={t.about.subtitle} jsonLd={aboutJsonLd}>
  <SiteHeader slot="header" lang={currentLang} />
  <MenuOverlay slot="header" lang={currentLang} />

  <!-- Hero Banner -->
  <section class="hero-dark relative overflow-hidden" aria-label={t.about.title}>
    <div class="absolute inset-0 about-hero-bg" aria-hidden="true">
      <div class="stars"></div>
    </div>
    <div class="container-wide relative z-10 py-16 md:py-24 lg:py-32 text-center">
      <p class="text-saffron font-semibold text-sm uppercase tracking-widest mb-4">
        {siteConfig.name}
      </p>
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold font-heading leading-tight mb-6">
        {t.about.title}
      </h1>
      <p class="text-cream/70 text-lg md:text-xl max-w-2xl mx-auto leading-relaxed">
        {t.about.heroTagline}
      </p>
    </div>
  </section>

  <!-- Bio Section -->
  <section class="py-16 md:py-24 bg-cream" aria-labelledby="bio-heading">
    <div class="container-wide">
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-12 items-start">
        <!-- Photo placeholder -->
        <div class="lg:col-span-2 flex justify-center">
          <div class="relative w-72 h-80 md:w-80 md:h-96 rounded-2xl border-4 border-gold/20 overflow-hidden bg-indigo/5 flex items-center justify-center shadow-lg">
            <div class="text-center text-indigo/30">
              <svg class="w-24 h-24 mx-auto mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
              </svg>
              <p class="text-sm font-medium">{siteConfig.astrologer.name}</p>
            </div>
            <!-- Decorative corner accents -->
            <div class="absolute top-0 left-0 w-8 h-8 border-t-2 border-l-2 border-gold/40 rounded-tl-2xl"></div>
            <div class="absolute bottom-0 right-0 w-8 h-8 border-b-2 border-r-2 border-gold/40 rounded-br-2xl"></div>
          </div>
        </div>

        <!-- Bio content -->
        <div class="lg:col-span-3">
          <h2 id="bio-heading" class="font-heading text-3xl md:text-4xl font-bold text-indigo mb-2">
            {t.about.bioTitle}
          </h2>
          <span class="mandala-accent" aria-hidden="true"></span>

          <div class="mt-6 space-y-5 text-indigo/80 text-base md:text-lg leading-relaxed">
            <p>{t.about.bio1}</p>
            <p>{t.about.bio2}</p>
            <p>{t.about.bio3}</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Credentials Section -->
  <section class="py-16 md:py-20 bg-white" aria-labelledby="credentials-heading">
    <div class="container-narrow">
      <SectionHeading title={t.about.credentialsTitle} subtitle={t.about.subtitle} />

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 md:gap-6">
        {t.about.credentials.map((credential: string) => (
          <div class="flex items-start gap-3 p-4 rounded-xl bg-cream/50 border border-gold/10 hover:border-gold/30 transition-colors">
            <svg class="w-5 h-5 text-gold mt-0.5 shrink-0" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd" />
            </svg>
            <span class="text-indigo font-medium">{credential}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Timeline Section -->
  <section class="py-16 md:py-20 bg-cream" aria-labelledby="timeline-heading">
    <div class="container-narrow">
      <SectionHeading title={t.about.timelineTitle} />

      <div class="relative">
        <!-- Timeline line -->
        <div class="absolute left-4 md:left-1/2 top-0 bottom-0 w-0.5 bg-gold/20 -translate-x-1/2 hidden md:block" aria-hidden="true"></div>
        <div class="absolute left-6 top-0 bottom-0 w-0.5 bg-gold/20 md:hidden" aria-hidden="true"></div>

        <div class="space-y-8 md:space-y-12">
          {t.about.timeline.map((item: { period: string; title: string; description: string }, index: number) => (
            <div class:list={['relative flex flex-col md:flex-row items-start gap-4 md:gap-8', index % 2 === 0 ? 'md:flex-row' : 'md:flex-row-reverse']}>
              <!-- Timeline dot -->
              <div class="absolute left-6 md:left-1/2 w-3 h-3 bg-gold rounded-full -translate-x-1/2 mt-2 z-10 ring-4 ring-cream" aria-hidden="true"></div>

              <!-- Content card -->
              <div class:list={['ml-12 md:ml-0 md:w-5/12', index % 2 === 0 ? 'md:text-right md:pr-8' : 'md:text-left md:pl-8']}>
                <span class="text-saffron font-semibold text-sm uppercase tracking-wider">{item.period}</span>
                <h3 class="font-heading text-xl font-bold text-indigo mt-1 mb-2">{item.title}</h3>
                <p class="text-indigo/70 leading-relaxed">{item.description}</p>
              </div>

              <!-- Spacer for alternating layout -->
              <div class="hidden md:block md:w-5/12"></div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Philosophy Section -->
  <section class="hero-dark relative overflow-hidden py-16 md:py-24" aria-labelledby="philosophy-heading">
    <div class="absolute inset-0 philosophy-bg" aria-hidden="true"></div>
    <div class="container-narrow relative z-10 text-center">
      <h2 id="philosophy-heading" class="text-3xl md:text-4xl font-bold font-heading mb-4">
        {t.about.philosophyTitle}
      </h2>
      <div class="mandala-accent-center mb-8"></div>

      <blockquote class="text-cream/80 text-lg md:text-xl lg:text-2xl leading-relaxed italic max-w-3xl mx-auto">
        <svg class="w-8 h-8 text-gold/40 mx-auto mb-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10H14.017zM0 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151C7.546 6.068 5.983 8.789 5.983 11h4v10H0z" />
        </svg>
        "{t.about.philosophy}"
      </blockquote>

      <p class="mt-6 text-gold font-heading text-lg font-semibold">— {siteConfig.astrologer.name}</p>
    </div>
  </section>

  <!-- Consultation Modes Section -->
  <section class="py-16 md:py-20 bg-white" aria-labelledby="consultation-heading">
    <div class="container-narrow">
      <SectionHeading title={t.about.consultationTitle} />

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {t.about.consultationModes.map((item: { mode: string; description: string }, index: number) => {
          const icons = [
            /* In-Person */ '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />',
            /* Zoom */ '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="m15.75 10.5 4.72-4.72a.75.75 0 0 1 1.28.53v11.38a.75.75 0 0 1-1.28.53l-4.72-4.72M4.5 18.75h9a2.25 2.25 0 0 0 2.25-2.25v-9a2.25 2.25 0 0 0-2.25-2.25h-9A2.25 2.25 0 0 0 2.25 7.5v9a2.25 2.25 0 0 0 2.25 2.25z" />',
            /* WhatsApp */ '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />'
          ];
          return (
            <div class="text-center p-6 rounded-2xl bg-cream/50 border border-gold/10 hover:border-gold/30 hover:shadow-md transition-all">
              <div class="w-14 h-14 mx-auto mb-4 rounded-full bg-gold/10 flex items-center justify-center">
                <svg class="w-7 h-7 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true" set:html={icons[index]} />
              </div>
              <h3 class="font-heading text-lg font-bold text-indigo mb-2">{item.mode}</h3>
              <p class="text-indigo/70 text-sm leading-relaxed">{item.description}</p>
            </div>
          );
        })}
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="hero-dark relative overflow-hidden py-16 md:py-24" aria-labelledby="about-cta-heading">
    <div class="absolute inset-0 cta-bg" aria-hidden="true"></div>
    <div class="container-narrow relative z-10 text-center">
      <h2 id="about-cta-heading" class="text-3xl md:text-4xl font-bold font-heading mb-4">
        {t.about.ctaTitle}
      </h2>
      <div class="mandala-accent-center mb-6"></div>
      <p class="text-cream/70 text-lg md:text-xl mb-10 max-w-2xl mx-auto leading-relaxed">
        {t.about.ctaSubtitle}
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <Button href={whatsappUrl} variant="primary" size="lg" target="_blank" rel="noopener noreferrer">
          {t.cta.button}
        </Button>
        <Button href={`tel:${siteConfig.contact.phone}`} variant="outline" size="lg">
          {t.cta.phone}
        </Button>
      </div>
    </div>
  </section>

  <SiteFooter slot="footer" lang={currentLang} />
  <WhatsAppButton slot="footer" lang={currentLang} />
  <BottomBar slot="footer" lang={currentLang} />
</BaseLayout>

<style>
  .about-hero-bg {
    background: linear-gradient(135deg, var(--color-indigo-dark) 0%, var(--color-indigo) 40%, var(--color-purple-dark) 100%);
  }

  .stars {
    position: absolute;
    inset: 0;
    background-image:
      radial-gradient(1px 1px at 15% 25%, rgba(255,255,255,0.4) 0%, transparent 100%),
      radial-gradient(1px 1px at 35% 55%, rgba(255,255,255,0.3) 0%, transparent 100%),
      radial-gradient(1.5px 1.5px at 55% 15%, rgba(255,255,255,0.5) 0%, transparent 100%),
      radial-gradient(1px 1px at 75% 45%, rgba(255,255,255,0.3) 0%, transparent 100%),
      radial-gradient(1px 1px at 85% 75%, rgba(255,255,255,0.4) 0%, transparent 100%);
  }

  .philosophy-bg {
    background: linear-gradient(135deg, var(--color-indigo-dark) 0%, var(--color-purple-dark) 100%);
  }

  .philosophy-bg::after {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 30% 50%, rgba(201, 168, 76, 0.06) 0%, transparent 50%),
      radial-gradient(circle at 70% 50%, rgba(255, 153, 51, 0.04) 0%, transparent 50%);
  }

  .cta-bg {
    background: linear-gradient(135deg, var(--color-indigo-dark) 0%, var(--color-purple-dark) 100%);
  }

  .cta-bg::after {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 20% 50%, rgba(201, 168, 76, 0.08) 0%, transparent 50%),
      radial-gradient(circle at 80% 50%, rgba(255, 153, 51, 0.06) 0%, transparent 50%);
  }
</style>
