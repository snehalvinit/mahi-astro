---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import SiteHeader from '../../../components/layout/SiteHeader.astro';
import MenuOverlay from '../../../components/layout/MenuOverlay.astro';
import SiteFooter from '../../../components/layout/SiteFooter.astro';
import WhatsAppButton from '../../../components/layout/WhatsAppButton.astro';
import BottomBar from '../../../components/layout/BottomBar.astro';
import Button from '../../../components/ui/Button.astro';
import Card from '../../../components/ui/Card.astro';
import Breadcrumbs from '../../../components/ui/Breadcrumbs.astro';
import CTASection from '../../../components/sections/CTASection.astro';
import { supportedLanguages, isValidLanguage, getTranslations } from '../../../utils/i18n';
import { getBlogPostsForLanguage, getAllBlogSlugs, getBlogPostBySlug, formatDate } from '../../../utils/blog';
import { getServiceBySlug } from '../../../utils/services';
import { siteConfig } from '../../../data/site-config';
import { articleSchema } from '../../../utils/schema';
import type { SupportedLanguage } from '../../../utils/i18n';

export async function getStaticPaths() {
  const slugs = await getAllBlogSlugs();
  const paths = [];
  for (const lang of supportedLanguages) {
    for (const slug of slugs) {
      paths.push({ params: { lang, slug } });
    }
  }
  return paths;
}

const { lang, slug } = Astro.params;
if (!isValidLanguage(lang as string)) {
  return Astro.redirect('/en/');
}

const currentLang = lang as SupportedLanguage;
const t = getTranslations(currentLang);
const post = await getBlogPostBySlug(currentLang, slug as string);

if (!post) {
  return Astro.redirect(`/${currentLang}/blog/`);
}

// Get related posts (same category, exclude current)
const allPosts = await getBlogPostsForLanguage(currentLang);
const relatedPosts = allPosts
  .filter((p) => p.slug !== post.slug && p.category === post.category)
  .slice(0, 3);

// Get related services data
const relatedServices = [];
if (post.relatedServices) {
  for (const serviceSlug of post.relatedServices) {
    const service = await getServiceBySlug(currentLang, serviceSlug);
    if (service) relatedServices.push(service);
  }
}

// Social sharing URLs
const siteUrl = Astro.site ? Astro.site.origin : 'https://believeastrology.com';
const pageUrl = `${siteUrl}/${currentLang}/blog/${post.slug}`;
const encodedUrl = encodeURIComponent(pageUrl);
const encodedTitle = encodeURIComponent(post.title);
const whatsappShare = `https://wa.me/?text=${encodedTitle}%20${encodedUrl}`;
const facebookShare = `https://www.facebook.com/sharer/sharer.php?u=${encodedUrl}`;
const twitterShare = `https://twitter.com/intent/tweet?text=${encodedTitle}&url=${encodedUrl}`;

// Map blog categories to image file slugs
const categoryImageMap: Record<string, string> = {
  'Vedic Astrology': 'zodiac-signs',
  'वैदिक ज्योतिष': 'zodiac-signs',
  'વૈદિક જ્યોતિષ': 'zodiac-signs',
  'Vastu Shastra': 'vastu-tips',
  'वास्तु शास्त्र': 'vastu-tips',
  'વાસ્તુ શાસ્ત્ર': 'vastu-tips',
  'Gemstones & Remedies': 'remedies-solutions',
  'रत्न और उपाय': 'remedies-solutions',
  'રત્નો અને ઉપાય': 'remedies-solutions',
  'Spiritual Wellness': 'spiritual-growth',
  'आध्यात्मिक कल्याण': 'spiritual-growth',
  'આધ્યાત્મિક કલ્યાણ': 'spiritual-growth',
  'Marriage & Relationships': 'zodiac-signs',
  'विवाह और रिश्ते': 'zodiac-signs',
  'લગ્ન અને સંબંધો': 'zodiac-signs',
  'Mantras & Spiritual Practice': 'spiritual-growth',
  'मंत्र और आध्यात्मिक अभ्यास': 'spiritual-growth',
  'મંત્ર અને આધ્યાત્મિક અભ્યાસ': 'spiritual-growth',
};
const blogOgImage = post.heroImage || `/images/blog/${categoryImageMap[post.category] || 'zodiac-signs'}.svg`;

const blogJsonLd = articleSchema(post, currentLang);
const breadcrumbItems = [
  { label: t.header.home, href: `/${currentLang}/` },
  { label: t.header.blog, href: `/${currentLang}/blog/` },
  { label: post.title, href: `/${currentLang}/blog/${post.slug}` },
];
---

<BaseLayout
  lang={currentLang}
  title={post.seo.title}
  description={post.seo.description}
  ogImage={blogOgImage}
  ogType="article"
  article={{ publishDate: post.publishDate, author: post.author, tags: post.tags }}
  jsonLd={blogJsonLd}
>
  <SiteHeader slot="header" lang={currentLang} />
  <MenuOverlay slot="header" lang={currentLang} />

  <!-- Hero Banner -->
  <section class="hero-dark py-12 md:py-20">
    <div class="container-wide max-w-4xl mx-auto">
      <Breadcrumbs lang={currentLang} items={breadcrumbItems} variant="dark" />
      <div class="flex items-center gap-3 mb-4 text-sm text-cream/60">
        <span class="bg-gold/20 text-gold px-3 py-1 rounded-full font-semibold text-xs">
          {post.category}
        </span>
        <span>{post.readingTime} {t.blog.minRead}</span>
      </div>
      <h1 class="font-heading text-3xl md:text-4xl lg:text-5xl font-bold text-gold mb-4 leading-tight">
        {post.title}
      </h1>
      <p class="text-cream/70 text-lg mb-4">{post.excerpt}</p>
      <div class="flex items-center gap-4 text-sm text-cream/50">
        <span>{t.blog.by} {post.author}</span>
        <span>&bull;</span>
        <time datetime={post.publishDate}>{formatDate(post.publishDate, currentLang)}</time>
      </div>
    </div>
  </section>

  <!-- Article Content -->
  <article class="py-[--spacing-section-sm] md:py-[--spacing-section]">
    <div class="container-wide max-w-3xl mx-auto">
      <!-- Post Body -->
      <div
        class="prose prose-lg max-w-none text-purple/90 leading-relaxed
               [&_h2]:font-heading [&_h2]:text-indigo [&_h2]:text-2xl [&_h2]:font-bold [&_h2]:mt-10 [&_h2]:mb-4
               [&_h3]:font-heading [&_h3]:text-indigo [&_h3]:text-xl [&_h3]:font-semibold [&_h3]:mt-8 [&_h3]:mb-3
               [&_p]:mb-4
               [&_ul]:mb-4 [&_ul]:pl-6 [&_ul]:list-disc [&_ul]:space-y-2
               [&_ol]:mb-4 [&_ol]:pl-6 [&_ol]:list-decimal [&_ol]:space-y-2
               [&_li]:text-purple/80
               [&_strong]:text-indigo [&_strong]:font-semibold
               [&_em]:text-purple/70
               [&_blockquote]:border-l-4 [&_blockquote]:border-gold [&_blockquote]:pl-4 [&_blockquote]:italic [&_blockquote]:text-purple/70 [&_blockquote]:my-6
               [&_a]:text-gold [&_a]:underline [&_a]:hover:text-saffron"
        set:html={post.content}
      />

      <!-- Tags -->
      {post.tags.length > 0 && (
        <div class="mt-10 pt-6 border-t border-purple/10">
          <div class="flex flex-wrap gap-2">
            {post.tags.map((tag) => (
              <span class="bg-purple/5 text-purple/60 px-3 py-1 rounded-full text-xs font-medium">
                #{tag}
              </span>
            ))}
          </div>
        </div>
      )}

      <!-- Social Sharing -->
      <div class="mt-8 pt-6 border-t border-purple/10">
        <p class="text-sm font-semibold text-indigo mb-3">{t.blog.shareTitle}</p>
        <div class="flex gap-3">
          <a
            href={whatsappShare}
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-2 px-4 py-2 rounded-lg bg-green-600 text-white text-sm font-medium hover:bg-green-700 transition-colors"
            aria-label={t.blog.shareWhatsApp}
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            {t.blog.shareWhatsApp}
          </a>
          <a
            href={facebookShare}
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-2 px-4 py-2 rounded-lg bg-blue-600 text-white text-sm font-medium hover:bg-blue-700 transition-colors"
            aria-label={t.blog.shareFacebook}
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
            FB
          </a>
          <a
            href={twitterShare}
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-2 px-4 py-2 rounded-lg bg-black text-white text-sm font-medium hover:bg-gray-800 transition-colors"
            aria-label={t.blog.shareTwitter}
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
            X
          </a>
        </div>
      </div>

      <!-- Book CTA -->
      <div class="mt-8 p-6 bg-gradient-to-r from-indigo/5 to-purple/5 rounded-xl border border-gold/20 text-center">
        <p class="text-indigo font-semibold mb-3">{t.blog.bookCta}</p>
        <Button
          href={`${siteConfig.contact.whatsapp}?text=${encodeURIComponent(t.whatsapp.prefill)}`}
          variant="primary"
          size="md"
        >
          {t.cta.button}
        </Button>
      </div>
    </div>
  </article>

  <!-- Related Services -->
  {relatedServices.length > 0 && (
    <section class="py-[--spacing-section-sm] md:py-[--spacing-section] bg-cream/50">
      <div class="container-wide max-w-4xl mx-auto">
        <h2 class="font-heading text-2xl font-bold text-indigo mb-6">{t.blog.relatedServices}</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
          {relatedServices.map((service) => (
            <a href={`/${currentLang}/services/${service.slug}`} class="block group">
              <Card variant="service" class="h-full">
                <h3 class="text-lg font-semibold font-heading text-indigo mb-2 group-hover:text-gold transition-colors">
                  {service.title}
                </h3>
                <p class="text-sm text-purple/70 leading-relaxed">
                  {service.shortDescription}
                </p>
                <span class="text-gold font-semibold text-sm mt-3 inline-block group-hover:underline">
                  {t.services.learnMore} &rarr;
                </span>
              </Card>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Related Posts -->
  {relatedPosts.length > 0 && (
    <section class="py-[--spacing-section-sm] md:py-[--spacing-section]">
      <div class="container-wide max-w-4xl mx-auto">
        <h2 class="font-heading text-2xl font-bold text-indigo mb-6">{t.blog.relatedPosts}</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {relatedPosts.map((rp) => (
            <a href={`/${currentLang}/blog/${rp.slug}`} class="block group">
              <Card variant="blog" class="h-full">
                <div class="flex items-center gap-2 mb-2 text-xs text-purple/60">
                  <span class="bg-gold/10 text-gold px-2 py-0.5 rounded-full font-semibold">
                    {rp.category}
                  </span>
                  <span>{rp.readingTime} {t.blog.minRead}</span>
                </div>
                <h3 class="text-base font-semibold font-heading text-indigo group-hover:text-gold transition-colors leading-snug">
                  {rp.title}
                </h3>
              </Card>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Back to Blog -->
  <div class="container-wide max-w-4xl mx-auto pb-8">
    <a
      href={`/${currentLang}/blog/`}
      class="text-gold font-semibold hover:underline inline-flex items-center gap-1"
    >
      &larr; {t.blog.backToBlog}
    </a>
  </div>

  <CTASection lang={currentLang} />

  <SiteFooter slot="footer" lang={currentLang} />
  <WhatsAppButton slot="footer" lang={currentLang} />
  <BottomBar slot="footer" lang={currentLang} />
</BaseLayout>
