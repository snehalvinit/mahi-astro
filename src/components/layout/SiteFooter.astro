---
import type { SupportedLanguage } from '../../utils/i18n';
import { getTranslations } from '../../utils/i18n';
import { siteConfig } from '../../data/site-config';

export interface Props {
  lang: SupportedLanguage;
}

const { lang } = Astro.props;
const t = getTranslations(lang);

const quickLinks = [
  { label: t.header.home, href: `/${lang}/` },
  { label: t.header.about, href: `/${lang}/about` },
  { label: t.header.blog, href: `/${lang}/blog` },
  { label: t.header.testimonials, href: `/${lang}/testimonials` },
  { label: t.header.contact, href: `/${lang}/contact` },
];

const serviceLinks = [
  { label: 'Kundli Reading', href: `/${lang}/services/kundli-reading` },
  { label: 'Horoscope Analysis', href: `/${lang}/services/horoscope-analysis` },
  { label: 'Vastu Consultation', href: `/${lang}/services/vastu-consultation` },
  { label: 'Gemstone Recommendations', href: `/${lang}/services/gemstone-recommendations` },
  { label: 'Spiritual Poojas', href: `/${lang}/services/vedic-spiritual-poojas` },
];
---

<footer class="bg-indigo text-cream pt-16 pb-8 md:pb-24 lg:pb-8">
  <div class="container-wide">
    <!-- Top Section -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10 pb-10 border-b border-cream/10">

      <!-- Brand Column -->
      <div class="lg:col-span-1">
        <a href={`/${lang}/`} class="flex items-center gap-2 mb-4">
          <span class="text-2xl" aria-hidden="true">&#x1F549;</span>
          <span class="font-heading text-xl font-bold text-gold">{t.footer.brand}</span>
        </a>
        <p class="text-cream/70 text-sm mb-4">{t.footer.tagline}</p>
        <p class="text-cream/50 text-sm italic">"{siteConfig.quote}"</p>
      </div>

      <!-- Quick Links -->
      <div>
        <h3 class="font-heading text-gold text-lg font-semibold mb-4">{t.footer.quickLinks}</h3>
        <ul class="space-y-2">
          {quickLinks.map((link) => (
            <li>
              <a href={link.href} class="text-cream/70 hover:text-gold text-sm transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Services -->
      <div>
        <h3 class="font-heading text-gold text-lg font-semibold mb-4">{t.footer.ourServices}</h3>
        <ul class="space-y-2">
          {serviceLinks.map((link) => (
            <li>
              <a href={link.href} class="text-cream/70 hover:text-gold text-sm transition-colors">
                {link.label}
              </a>
            </li>
          ))}
          <li>
            <a href={`/${lang}/services`} class="text-gold text-sm font-medium hover:text-gold-light transition-colors">
              {t.services.viewAll} &rarr;
            </a>
          </li>
        </ul>
      </div>

      <!-- Contact Info -->
      <div>
        <h3 class="font-heading text-gold text-lg font-semibold mb-4">{t.footer.contactUs}</h3>
        <ul class="space-y-3">
          <li>
            <a href={`mailto:${siteConfig.contact.email}`} class="flex items-center gap-2 text-cream/70 hover:text-gold text-sm transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
              {siteConfig.contact.email}
            </a>
          </li>
          <li>
            <a href={`tel:${siteConfig.contact.phone.replace(/\s/g, '')}`} class="flex items-center gap-2 text-cream/70 hover:text-gold text-sm transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
              {siteConfig.contact.phone}
            </a>
          </li>
          <li class="flex items-center gap-2 text-cream/70 text-sm">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
            {t.footer.address}
          </li>
        </ul>

        <!-- Social Links -->
        <div class="mt-6">
          <h4 class="text-cream/50 text-sm mb-3">{t.footer.followUs}</h4>
          <div class="flex items-center gap-3">
            <a href={siteConfig.contact.whatsapp} target="_blank" rel="noopener noreferrer" class="w-9 h-9 flex items-center justify-center rounded-full bg-cream/10 text-cream/70 hover:bg-gold hover:text-indigo transition-all" aria-label="WhatsApp">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            </a>
            {siteConfig.social.instagram && (
              <a href={siteConfig.social.instagram} target="_blank" rel="noopener noreferrer" class="w-9 h-9 flex items-center justify-center rounded-full bg-cream/10 text-cream/70 hover:bg-gold hover:text-indigo transition-all" aria-label="Instagram">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>
              </a>
            )}
            {siteConfig.social.facebook && (
              <a href={siteConfig.social.facebook} target="_blank" rel="noopener noreferrer" class="w-9 h-9 flex items-center justify-center rounded-full bg-cream/10 text-cream/70 hover:bg-gold hover:text-indigo transition-all" aria-label="Facebook">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path></svg>
              </a>
            )}
            {siteConfig.social.youtube && (
              <a href={siteConfig.social.youtube} target="_blank" rel="noopener noreferrer" class="w-9 h-9 flex items-center justify-center rounded-full bg-cream/10 text-cream/70 hover:bg-gold hover:text-indigo transition-all" aria-label="YouTube">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22.54 6.42a2.78 2.78 0 0 0-1.94-2C18.88 4 12 4 12 4s-6.88 0-8.6.46a2.78 2.78 0 0 0-1.94 2A29 29 0 0 0 1 11.75a29 29 0 0 0 .46 5.33A2.78 2.78 0 0 0 3.4 19.13C5.12 19.56 12 19.56 12 19.56s6.88 0 8.6-.46a2.78 2.78 0 0 0 1.94-2 29 29 0 0 0 .46-5.25 29 29 0 0 0-.46-5.43z"></path><polygon points="9.75 15.02 15.5 11.75 9.75 8.48 9.75 15.02"></polygon></svg>
              </a>
            )}
          </div>
        </div>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="flex flex-col md:flex-row items-center justify-between gap-4 pt-8 text-sm text-cream/50">
      <p>{t.footer.copyright}</p>
      <p>{t.footer.madeWith}</p>
    </div>
  </div>
</footer>
