---
import type { SupportedLanguage } from '../../utils/i18n';
import { getTranslations } from '../../utils/i18n';
import { siteConfig } from '../../data/site-config';
import Button from '../ui/Button.astro';

export interface Props {
  lang: SupportedLanguage;
}

const { lang } = Astro.props;
const t = getTranslations(lang);

const navItems = [
  { label: t.header.home, href: `/${lang}/` },
  { label: t.header.about, href: `/${lang}/about` },
  { label: t.header.services, href: `/${lang}/services` },
  { label: t.header.blog, href: `/${lang}/blog` },
  { label: t.header.testimonials, href: `/${lang}/testimonials` },
  { label: t.header.events, href: `/${lang}/events` },
  { label: t.header.contact, href: `/${lang}/contact` },
];
---

<div
  id="menu-overlay"
  class="fixed inset-0 z-40 bg-cream translate-x-full transition-transform duration-300 ease-in-out lg:hidden"
  aria-hidden="true"
>
  <!-- Offset for header height -->
  <div class="pt-16 h-full overflow-y-auto">
    <nav class="flex flex-col px-6 py-8" aria-label="Mobile navigation">
      {navItems.map((item) => (
        <a
          href={item.href}
          class="py-4 text-xl font-heading font-semibold text-indigo hover:text-gold border-b border-gold/10 transition-colors"
        >
          {item.label}
        </a>
      ))}

      <div class="mt-8">
        <Button variant="primary" size="lg" href={`/${lang}/contact`} class="w-full text-center">
          {t.header.bookConsultation}
        </Button>
      </div>

      <!-- Contact info in mobile menu -->
      <div class="mt-8 pt-6 border-t border-gold/10">
        <a
          href={`mailto:${siteConfig.contact.email}`}
          class="flex items-center gap-3 py-3 text-purple/80 hover:text-gold transition-colors"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
          {siteConfig.contact.email}
        </a>
        <a
          href={`tel:${siteConfig.contact.phone.replace(/\s/g, '')}`}
          class="flex items-center gap-3 py-3 text-purple/80 hover:text-gold transition-colors"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
          {siteConfig.contact.phone}
        </a>
      </div>
    </nav>
  </div>
</div>
