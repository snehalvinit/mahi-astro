---
export interface Props {
  icon: string;
  title: string;
  description: string;
  date: string;
  endDate?: string;
  location?: string;
  category: string;
  status: string;
  categoryLabel: string;
  dateLabel: string;
  locationLabel: string;
  learnMoreLabel: string;
  whatsappUrl: string;
}

const { icon, title, description, date, endDate, location, category, status, categoryLabel, dateLabel, locationLabel, learnMoreLabel, whatsappUrl } = Astro.props;

const isUpcoming = status === 'upcoming';
const statusColor = isUpcoming ? 'bg-saffron/15 text-saffron' : 'bg-gold/15 text-gold';

function formatDate(dateStr: string, lang: string = 'en'): string {
  const d = new Date(dateStr + 'T00:00:00');
  return d.toLocaleDateString(lang === 'hi' ? 'hi-IN' : lang === 'gu' ? 'gu-IN' : 'en-IN', {
    day: 'numeric',
    month: 'short',
    year: 'numeric',
  });
}

const displayDate = endDate && endDate !== date
  ? `${formatDate(date)} — ${formatDate(endDate)}`
  : formatDate(date);
---

<article class="bg-white rounded-[var(--radius-card)] shadow-[var(--shadow-card)] overflow-hidden hover:shadow-lg transition-shadow duration-300 flex flex-col">
  <!-- Category & Status Badge -->
  <div class="flex items-center justify-between px-6 pt-5 pb-0">
    <span class={`text-xs font-semibold px-3 py-1 rounded-full ${statusColor}`}>
      {categoryLabel}
    </span>
    {isUpcoming && (
      <span class="text-xs font-medium text-saffron animate-pulse">● Live</span>
    )}
  </div>

  <div class="p-6 pt-3 flex-1 flex flex-col">
    <!-- Icon + Title -->
    <div class="flex items-start gap-3 mb-3">
      <span class="text-3xl flex-shrink-0" aria-hidden="true" set:html={icon} />
      <h3 class="font-heading text-lg font-bold text-indigo leading-snug">{title}</h3>
    </div>

    <!-- Date -->
    <div class="flex items-center gap-2 text-sm text-purple/70 mb-2">
      <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
      </svg>
      <span>{displayDate}</span>
    </div>

    <!-- Location -->
    {location && (
      <div class="flex items-center gap-2 text-sm text-purple/70 mb-4">
        <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
        </svg>
        <span>{location}</span>
      </div>
    )}

    <!-- Description -->
    <p class="text-sm text-indigo/70 leading-relaxed mb-5 flex-1">{description}</p>

    <!-- CTA -->
    {isUpcoming && (
      <a
        href={whatsappUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center justify-center gap-2 text-sm font-semibold text-white bg-green-600 hover:bg-green-700 rounded-[var(--radius-button)] px-5 py-2.5 transition-colors"
      >
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z" />
        </svg>
        {learnMoreLabel}
      </a>
    )}
  </div>
</article>
