---
import type { SupportedLanguage } from '../../utils/i18n';
import { getTranslations } from '../../utils/i18n';
import SectionHeading from '../ui/SectionHeading.astro';
import Card from '../ui/Card.astro';
import Button from '../ui/Button.astro';

interface Props {
  lang: SupportedLanguage;
}

const { lang } = Astro.props;
const t = getTranslations(lang);

const serviceKeys = [
  'kundli', 'horoscope', 'lifeGuidance', 'vastu', 'gemstone', 'karma',
  'panchaTatva', 'chakra', 'pooja', 'yagna', 'mrityunjay', 'mantra',
] as const;

const serviceIconFiles: Record<string, string> = {
  kundli: 'kundli-reading',
  horoscope: 'horoscope-analysis',
  lifeGuidance: 'life-guidance',
  vastu: 'vastu',
  gemstone: 'gemstone',
  karma: 'karma-counselling',
  panchaTatva: 'pancha-tatva',
  chakra: 'chakra-balancing',
  pooja: 'poojas',
  yagna: 'yagnas',
  mrityunjay: 'maha-mrityunjay',
  mantra: 'mantras-chanting',
};
---

<section id="services" class="py-[--spacing-section-sm] md:py-[--spacing-section]" aria-labelledby="services-heading">
  <div class="container-wide">
    <SectionHeading
      title={t.services.title}
      subtitle={t.services.subtitle}
      align="center"
    />

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
      {serviceKeys.map((key) => (
        <Card variant="service" class="group">
          <img slot="icon" src={`/images/icons/services/${serviceIconFiles[key]}.svg`} alt={t.services[key].name} width="40" height="40" class="w-10 h-10" loading="lazy" />
          <h3 class="text-lg font-semibold font-heading text-indigo mb-2 group-hover:text-gold transition-colors">
            {t.services[key].name}
          </h3>
          <p class="text-sm text-purple/70 leading-relaxed">
            {t.services[key].short}
          </p>
        </Card>
      ))}
    </div>

    <div class="text-center mt-10">
      <Button href={`/${lang}/services`} variant="outline" size="md">
        {t.services.viewAll}
      </Button>
    </div>
  </div>
</section>
