---
import type { SupportedLanguage } from '../../utils/i18n';
import { getTranslations } from '../../utils/i18n';
import SectionHeading from '../ui/SectionHeading.astro';
import Card from '../ui/Card.astro';
import Button from '../ui/Button.astro';

interface Props {
  lang: SupportedLanguage;
}

const { lang } = Astro.props;
const t = getTranslations(lang);

const serviceKeys = [
  'kundli', 'horoscope', 'lifeGuidance', 'vastu', 'gemstone', 'karma',
  'panchaTatva', 'chakra', 'pooja', 'yagna', 'mrityunjay', 'mantra',
] as const;

const serviceIcons: Record<string, string> = {
  kundli: '&#x1F52E;',       // crystal ball
  horoscope: '&#x2B50;',     // star
  lifeGuidance: '&#x1F3AF;', // target
  vastu: '&#x1F3E0;',        // house
  gemstone: '&#x1F48E;',     // gem
  karma: '&#x2638;',         // wheel of dharma
  panchaTatva: '&#x1F30D;',  // earth
  chakra: '&#x1F549;',       // om
  pooja: '&#x1F56F;',        // candle
  yagna: '&#x1F525;',        // fire
  mrityunjay: '&#x1F64F;',   // prayer
  mantra: '&#x1F3B6;',       // music notes
};
---

<section id="services" class="py-[--spacing-section-sm] md:py-[--spacing-section]" aria-labelledby="services-heading">
  <div class="container-wide">
    <SectionHeading
      title={t.services.title}
      subtitle={t.services.subtitle}
      align="center"
    />

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
      {serviceKeys.map((key) => (
        <Card variant="service" class="group">
          <span slot="icon" class="text-3xl" set:html={serviceIcons[key]} />
          <h3 class="text-lg font-semibold font-heading text-indigo mb-2 group-hover:text-gold transition-colors">
            {t.services[key].name}
          </h3>
          <p class="text-sm text-purple/70 leading-relaxed">
            {t.services[key].short}
          </p>
        </Card>
      ))}
    </div>

    <div class="text-center mt-10">
      <Button href={`/${lang}/services`} variant="outline" size="md">
        {t.services.viewAll}
      </Button>
    </div>
  </div>
</section>
