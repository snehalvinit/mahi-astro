---
import Button from '../ui/Button.astro';

export interface Props {
  title: string;
  subtitle: string;
  emailPlaceholder: string;
  emailLabel: string;
  submitLabel: string;
  submittingLabel: string;
  successMessage: string;
  errorMessage: string;
  whatsappTitle: string;
  whatsappDescription: string;
  whatsappCta: string;
  whatsappUrl: string;
  variant?: 'default' | 'compact';
}

const {
  title,
  subtitle,
  emailPlaceholder,
  emailLabel,
  submitLabel,
  submittingLabel,
  successMessage,
  errorMessage,
  whatsappTitle,
  whatsappDescription,
  whatsappCta,
  whatsappUrl,
  variant = 'default',
} = Astro.props;

const isCompact = variant === 'compact';
---

<section class={`${isCompact ? 'py-12' : 'py-[--spacing-section-sm] md:py-[--spacing-section]'} bg-indigo/5`} aria-labelledby="subscribe-heading">
  <div class="container-wide">
    <div class={`${isCompact ? 'max-w-2xl' : 'max-w-3xl'} mx-auto text-center`}>
      <h2 id="subscribe-heading" class={`font-heading ${isCompact ? 'text-2xl' : 'text-3xl md:text-4xl'} font-bold text-indigo mb-3`}>
        {title}
      </h2>
      <p class="text-purple/70 mb-8 max-w-xl mx-auto">{subtitle}</p>

      <div class={`grid ${isCompact ? 'gap-6' : 'md:grid-cols-2 gap-8'}`}>
        <!-- Email Subscription -->
        <div class="bg-white rounded-[var(--radius-card)] p-6 shadow-[var(--shadow-card)]">
          <div class="flex items-center gap-2 mb-4">
            <svg class="w-5 h-5 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
            <h3 class="font-semibold text-indigo">{emailLabel}</h3>
          </div>

          <form id="subscribe-form" class="space-y-3" action="https://formspree.io/f/placeholder-subscribe" method="POST">
            <input
              type="email"
              name="email"
              required
              placeholder={emailPlaceholder}
              class="w-full px-4 py-2.5 rounded-[var(--radius-button)] border border-gold/20 bg-cream/50 text-indigo placeholder-purple/40 focus:outline-none focus:ring-2 focus:ring-gold/40 focus:border-gold transition-colors text-sm"
            />
            <button
              type="submit"
              data-label={submitLabel}
              class="w-full px-4 py-2.5 rounded-[var(--radius-button)] bg-gold text-white font-semibold text-sm hover:bg-gold/90 transition-colors"
            >
              {submitLabel}
            </button>
          </form>

          <div id="subscribe-status" class="mt-3 text-sm hidden" data-success={successMessage} data-error={errorMessage}></div>
        </div>

        <!-- WhatsApp Subscribe -->
        <div class="bg-white rounded-[var(--radius-card)] p-6 shadow-[var(--shadow-card)] flex flex-col">
          <div class="flex items-center gap-2 mb-4">
            <svg class="w-5 h-5 text-green-600" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z" />
            </svg>
            <h3 class="font-semibold text-indigo">{whatsappTitle}</h3>
          </div>

          <p class="text-sm text-purple/70 mb-4 flex-1">{whatsappDescription}</p>

          <a
            href={whatsappUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center gap-2 w-full px-4 py-2.5 rounded-[var(--radius-button)] bg-green-600 text-white font-semibold text-sm hover:bg-green-700 transition-colors"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z" />
            </svg>
            {whatsappCta}
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById('subscribe-form') as HTMLFormElement | null;
  const statusDiv = document.getElementById('subscribe-status');

  if (form && statusDiv) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      const button = form.querySelector('button[type="submit"]') as HTMLButtonElement;
      const originalText = button.dataset.label || button.textContent || '';
      button.textContent = '...';
      button.disabled = true;

      try {
        const response = await fetch(form.action, {
          method: 'POST',
          body: new FormData(form),
          headers: { Accept: 'application/json' },
        });

        if (response.ok) {
          statusDiv.textContent = statusDiv.dataset.success || 'Subscribed!';
          statusDiv.className = 'mt-3 text-sm text-green-700 bg-green-50 p-2 rounded';
          form.reset();
        } else {
          throw new Error('Failed');
        }
      } catch {
        statusDiv.textContent = statusDiv.dataset.error || 'Something went wrong.';
        statusDiv.className = 'mt-3 text-sm text-red-700 bg-red-50 p-2 rounded';
      } finally {
        button.textContent = originalText;
        button.disabled = false;
      }
    });
  }
</script>
