---
import type { SupportedLanguage } from '../../utils/i18n';
import { getTranslations } from '../../utils/i18n';
import { siteConfig } from '../../data/site-config';
import Button from '../ui/Button.astro';

interface Props {
  lang: SupportedLanguage;
}

const { lang } = Astro.props;
const t = getTranslations(lang);

const whatsappUrl = `${siteConfig.contact.whatsapp}?text=${encodeURIComponent(t.whatsapp.prefill)}`;
---

<section class="hero-dark relative overflow-hidden" aria-label={t.hero.headline}>
  <!-- Celestial background pattern -->
  <div class="absolute inset-0 hero-bg" aria-hidden="true">
    <div class="stars"></div>
    <div class="mandala-glow"></div>
  </div>

  <div class="container-wide relative z-10 py-20 md:py-28 lg:py-36">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
      <!-- Left: Content -->
      <div class="text-center lg:text-left">
        <p class="text-saffron font-semibold text-sm md:text-base uppercase tracking-widest mb-4">
          {t.hero.subtitle}
        </p>

        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold font-heading leading-tight mb-6">
          {t.hero.headline}
        </h1>

        <p class="text-cream/70 text-sm md:text-base mb-6 tracking-wide">
          {t.hero.credentials}
        </p>

        <blockquote class="text-cream/60 italic text-base md:text-lg leading-relaxed mb-8 max-w-xl mx-auto lg:mx-0 border-l-2 border-gold/30 pl-4">
          "{t.hero.tagline}"
        </blockquote>

        <!-- CTAs -->
        <div class="flex flex-col sm:flex-row gap-4 justify-center lg:justify-start">
          <Button href={whatsappUrl} variant="primary" size="lg" target="_blank" rel="noopener noreferrer">
            {t.hero.cta}
          </Button>
          <Button href={`/${lang}/#services`} variant="outline" size="lg">
            {t.hero.ctaSecondary}
          </Button>
        </div>

        <!-- Quick contact -->
        <div class="mt-6 flex flex-col sm:flex-row gap-4 justify-center lg:justify-start text-sm text-cream/60">
          <a href={`tel:${siteConfig.contact.phone}`} class="inline-flex items-center gap-2 hover:text-gold transition-colors">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            {t.hero.callNow}: {siteConfig.contact.phone}
          </a>
          <a href={`mailto:${siteConfig.contact.email}`} class="inline-flex items-center gap-2 hover:text-gold transition-colors">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
            {siteConfig.contact.email}
          </a>
        </div>
      </div>

      <!-- Right: Astrologer photo placeholder -->
      <div class="hidden lg:flex justify-center">
        <div class="relative w-80 h-80 rounded-full border-4 border-gold/30 overflow-hidden bg-indigo-light/20 flex items-center justify-center">
          <div class="text-center text-cream/40">
            <svg class="w-24 h-24 mx-auto mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
            </svg>
            <p class="text-xs">Pandit Shree Mahadev Joshi</p>
          </div>
          <!-- Decorative ring -->
          <div class="absolute inset-0 rounded-full border-2 border-gold/10 scale-110"></div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero-bg {
    background: linear-gradient(135deg, var(--color-indigo-dark) 0%, var(--color-indigo) 40%, var(--color-purple-dark) 100%);
  }

  .stars {
    position: absolute;
    inset: 0;
    background-image:
      radial-gradient(1px 1px at 10% 20%, rgba(255,255,255,0.4) 0%, transparent 100%),
      radial-gradient(1px 1px at 30% 60%, rgba(255,255,255,0.3) 0%, transparent 100%),
      radial-gradient(1.5px 1.5px at 50% 10%, rgba(255,255,255,0.5) 0%, transparent 100%),
      radial-gradient(1px 1px at 70% 40%, rgba(255,255,255,0.3) 0%, transparent 100%),
      radial-gradient(1px 1px at 90% 80%, rgba(255,255,255,0.4) 0%, transparent 100%),
      radial-gradient(1.5px 1.5px at 20% 90%, rgba(255,255,255,0.3) 0%, transparent 100%),
      radial-gradient(1px 1px at 60% 70%, rgba(255,255,255,0.2) 0%, transparent 100%),
      radial-gradient(1px 1px at 80% 15%, rgba(255,255,255,0.35) 0%, transparent 100%);
  }

  .mandala-glow {
    position: absolute;
    top: 50%;
    right: -10%;
    width: 60%;
    height: 80%;
    transform: translateY(-50%);
    background: radial-gradient(circle, rgba(201, 168, 76, 0.06) 0%, transparent 70%);
    border-radius: 50%;
  }
</style>
