---
import type { SupportedLanguage } from '../../utils/i18n';
import { getTranslations } from '../../utils/i18n';
import SectionHeading from '../ui/SectionHeading.astro';
import Card from '../ui/Card.astro';

interface Props {
  lang: SupportedLanguage;
}

const { lang } = Astro.props;
const t = getTranslations(lang);
const reviews = t.testimonials.reviews;
---

<section class="bg-cream-dark/30 py-[--spacing-section-sm] md:py-[--spacing-section]" aria-labelledby="testimonials-heading">
  <div class="container-wide">
    <SectionHeading
      title={t.testimonials.title}
      subtitle={t.testimonials.subtitle}
      align="center"
    />

    <div class="testimonials-scroll overflow-x-auto pb-4 -mx-4 px-4 md:mx-0 md:px-0 md:overflow-visible">
      <div class="flex md:grid md:grid-cols-2 lg:grid-cols-3 gap-6 min-w-max md:min-w-0">
        {reviews.map((review: any) => (
          <Card variant="testimonial" class="w-80 md:w-auto flex-shrink-0 md:flex-shrink">
            <div class="flex items-center gap-3 mb-4">
              <!-- Avatar initial -->
              <div class="w-12 h-12 rounded-full bg-gold/15 flex items-center justify-center text-gold font-bold text-lg">
                {review.name.charAt(0)}
              </div>
              <div>
                <p class="font-semibold text-indigo">{review.name}</p>
                <p class="text-xs text-purple/60">{review.location}</p>
              </div>
            </div>

            <!-- Star rating -->
            <div class="flex gap-0.5 mb-3" aria-label={`${review.rating} out of 5 stars`}>
              {Array.from({ length: 5 }).map((_, i) => (
                <svg
                  class={`w-4 h-4 ${i < review.rating ? 'text-saffron' : 'text-gray-300'}`}
                  fill="currentColor"
                  viewBox="0 0 20 20"
                  aria-hidden="true"
                >
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
              ))}
            </div>

            <p class="text-sm text-indigo/80 leading-relaxed italic">
              "{review.text}"
            </p>
          </Card>
        ))}
      </div>
    </div>

    <!-- Scroll hint on mobile -->
    <p class="text-center text-xs text-purple/40 mt-2 md:hidden" aria-hidden="true">
      ← swipe →
    </p>
  </div>
</section>

<style>
  .testimonials-scroll::-webkit-scrollbar {
    height: 4px;
  }
  .testimonials-scroll::-webkit-scrollbar-track {
    background: transparent;
  }
  .testimonials-scroll::-webkit-scrollbar-thumb {
    background: var(--color-gold);
    border-radius: 2px;
    opacity: 0.3;
  }
</style>
