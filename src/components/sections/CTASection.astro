---
import type { SupportedLanguage } from '../../utils/i18n';
import { getTranslations } from '../../utils/i18n';
import { siteConfig } from '../../data/site-config';
import Button from '../ui/Button.astro';

interface Props {
  lang: SupportedLanguage;
}

const { lang } = Astro.props;
const t = getTranslations(lang);

const whatsappUrl = `${siteConfig.contact.whatsapp}?text=${encodeURIComponent(t.whatsapp.prefill)}`;
---

<section class="hero-dark relative overflow-hidden py-16 md:py-24" aria-labelledby="cta-heading">
  <!-- Subtle pattern background -->
  <div class="absolute inset-0 cta-bg" aria-hidden="true"></div>

  <div class="container-narrow relative z-10 text-center">
    <h2 id="cta-heading" class="text-3xl md:text-4xl font-bold font-heading mb-4">
      {t.cta.title}
    </h2>

    <div class="mandala-accent-center mb-6"></div>

    <p class="text-cream/70 text-lg md:text-xl mb-10 max-w-2xl mx-auto leading-relaxed">
      {t.cta.subtitle}
    </p>

    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <Button href={whatsappUrl} variant="primary" size="lg" target="_blank" rel="noopener noreferrer">
        <svg class="w-5 h-5 mr-2" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z" />
        </svg>
        {t.cta.button}
      </Button>
      <Button href={`tel:${siteConfig.contact.phone}`} variant="outline" size="lg">
        <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
        </svg>
        {t.cta.phone}
      </Button>
    </div>
  </div>
</section>

<style>
  .cta-bg {
    background:
      linear-gradient(135deg, var(--color-indigo-dark) 0%, var(--color-purple-dark) 100%);
  }

  .cta-bg::after {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 20% 50%, rgba(201, 168, 76, 0.08) 0%, transparent 50%),
      radial-gradient(circle at 80% 50%, rgba(255, 153, 51, 0.06) 0%, transparent 50%);
  }
</style>
