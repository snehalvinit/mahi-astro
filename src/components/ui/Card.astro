---
export interface Props {
  variant?: 'service' | 'testimonial' | 'blog';
  class?: string;
}

const { variant = 'service', class: className = '' } = Astro.props;

const baseClasses = 'rounded-[var(--radius-card)] transition-all duration-300';

const variantClasses: Record<string, string> = {
  service: 'bg-white p-6 shadow-[var(--shadow-card)] hover:shadow-[var(--shadow-card-hover)] hover:-translate-y-1 border border-cream-dark',
  testimonial: 'bg-white p-6 shadow-[var(--shadow-card)] border-l-4 border-l-gold',
  blog: 'bg-white overflow-hidden shadow-[var(--shadow-card)] hover:shadow-[var(--shadow-card-hover)] hover:-translate-y-1',
};

const classes = [baseClasses, variantClasses[variant], className].join(' ');
---

<div class={classes}>
  {variant === 'service' && (
    <div class="mb-4">
      <slot name="icon" />
    </div>
  )}
  {variant === 'blog' && (
    <div class="aspect-video overflow-hidden">
      <slot name="image" />
    </div>
  )}
  <div class={variant === 'blog' ? 'p-6' : ''}>
    <slot />
  </div>
</div>
