---
export interface Props {
  title: string;
  subtitle?: string;
  align?: 'left' | 'center';
  dark?: boolean;
  class?: string;
}

const {
  title,
  subtitle,
  align = 'center',
  dark = false,
  class: className = '',
} = Astro.props;

const alignClasses = align === 'center' ? 'text-center' : 'text-left';
const titleColor = dark ? 'text-gold' : 'text-indigo';
const subtitleColor = dark ? 'text-cream/80' : 'text-purple';
const accentClass = align === 'center' ? 'mandala-accent-center' : 'mandala-accent';
---

<div class:list={['mb-12', alignClasses, className]}>
  <h2 class:list={['font-heading text-3xl md:text-4xl font-bold', titleColor]}>
    {title}
  </h2>
  <span class={accentClass} aria-hidden="true"></span>
  {subtitle && (
    <p class:list={['mt-4 text-lg max-w-2xl', subtitleColor, align === 'center' && 'mx-auto']}>
      {subtitle}
    </p>
  )}
</div>
