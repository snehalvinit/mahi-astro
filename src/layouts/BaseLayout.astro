---
import type { SupportedLanguage } from '../utils/i18n';
import { getTranslations } from '../utils/i18n';
import SEOHead from '../components/SEOHead.astro';
import AnalyticsHead from '../components/AnalyticsHead.astro';
import CookieConsent from '../components/layout/CookieConsent.astro';
import '../styles/global.css';

export interface Props {
  lang: SupportedLanguage;
  title?: string;
  description?: string;
  ogImage?: string;
  ogType?: 'website' | 'article';
  article?: {
    publishDate: string;
    author: string;
    tags: string[];
  };
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const { lang, title, description, ogImage, ogType, article, jsonLd } = Astro.props;
const t = getTranslations(lang);
const pageTitle = title || t.meta.title;
const pageDescription = description || t.meta.description;
const canonicalPath = Astro.url.pathname;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="keywords" content={t.meta.keywords} />

    <title>{pageTitle}</title>

    <SEOHead
      lang={lang}
      title={pageTitle}
      description={pageDescription}
      canonicalPath={canonicalPath}
      ogImage={ogImage}
      ogType={ogType}
      article={article}
      jsonLd={jsonLd}
    />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Google Fonts: preconnect for performance -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Playfair+Display:wght@400;500;600;700&family=Noto+Sans+Devanagari:wght@400;500;600;700&family=Noto+Sans+Gujarati:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <AnalyticsHead />

    <slot name="head" />
  </head>
  <body class="antialiased">
    <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-[100] focus:bg-gold focus:text-indigo focus:px-4 focus:py-2 focus:rounded focus:font-semibold">
      Skip to content
    </a>

    <slot name="header" />

    <main id="main-content">
      <slot />
    </main>

    <slot name="footer" />
    <CookieConsent lang={lang} />
  </body>
</html>
