---
import type { SupportedLanguage } from '../utils/i18n';
import { getTranslations, getAlternateLanguages } from '../utils/i18n';
import { siteConfig } from '../data/site-config';
import CookieConsent from '../components/layout/CookieConsent.astro';
import '../styles/global.css';

export interface Props {
  lang: SupportedLanguage;
  title?: string;
  description?: string;
}

const { lang, title, description } = Astro.props;
const t = getTranslations(lang);
const pageTitle = title || t.meta.title;
const pageDescription = description || t.meta.description;
const alternateLanguages = getAlternateLanguages(lang);
const canonicalUrl = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={pageDescription} />
    <meta name="keywords" content={t.meta.keywords} />
    <meta name="author" content={siteConfig.astrologer.name} />

    <title>{pageTitle}</title>

    <link rel="canonical" href={canonicalUrl.href} />
    <link rel="alternate" hreflang={lang} href={canonicalUrl.href} />
    {alternateLanguages.map((altLang) => (
      <link
        rel="alternate"
        hreflang={altLang}
        href={new URL(`/${altLang}${Astro.url.pathname.replace(/^\/(en|hi|gu)/, '')}`, Astro.site).href}
      />
    ))}
    <link rel="alternate" hreflang="x-default" href={new URL(`/en${Astro.url.pathname.replace(/^\/(en|hi|gu)/, '')}`, Astro.site).href} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Google Fonts: preconnect for performance -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Playfair+Display:wght@400;500;600;700&family=Noto+Sans+Devanagari:wght@400;500;600;700&family=Noto+Sans+Gujarati:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <slot name="head" />
  </head>
  <body class="antialiased">
    <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-50 focus:bg-gold focus:text-indigo focus:px-4 focus:py-2 focus:rounded focus:font-semibold">
      Skip to main content
    </a>

    <slot name="header" />

    <main id="main-content">
      <slot />
    </main>

    <slot name="footer" />
    <CookieConsent lang={lang} />
  </body>
</html>
